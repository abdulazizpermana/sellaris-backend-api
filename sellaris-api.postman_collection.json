          "raw": "{\n  \"product_name\": \"Keripik Pisang\",\n  \"price\": 25000,\n  \"stock\": 80,\n  \"description\": \"Keripik pisang gurih homemade, cocok untuk oleh-oleh.\",\n  \"target_market\": \"Wisatawan lokal\"\n}"
        }
      }
