{
  "info": {
    "name": "Sellaris API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "RESTful Sellaris API collection for Flutter frontend integration."
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/api/register", "host": ["{{base_url}}"], "path": ["api", "register"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"UMKM Owner\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"business_name\": \"Toko UMKM\",\n  \"category\": \"Food & Beverage\"\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [
