        ],
        "url": { "raw": "{{base_url}}/api/profile", "host": ["{{base_url}}"], "path": ["api", "profile"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"UMKM Owner\",\n  \"business_name\": \"Toko UMKM\",\n  \"business_category\": \"Food & Beverage\",\n  \"business_description\": \"Produk makanan ringan premium untuk pasar lokal.\",\n  \"dark_mode\": true,\n  \"language\": \"id\",\n  \"notification_enabled\": true,\n  \"ai_tone\": \"Friendly\",\n  \"default_target_market\": \"Gen Z Indonesia\",\n  \"default_platform\": \"Instagram\"\n}"
