        ],
        "url": { "raw": "{{base_url}}/api/products/:id", "host": ["{{base_url}}"], "path": ["api", "products", ":id"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stock\": 90,\n  \"price\": 26000\n}"
        }
      }
    },
    {
      "name": "Delete Product",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
